# Monitor APS — Banco de Dados e-SUS PEC (SOMENTE LEITURA)
ESUS_PEC_DB_HOST=localhost
ESUS_PEC_DB_PORT=5432
ESUS_PEC_DB_NAME=esus
ESUS_PEC_DB_USER=monitor_aps
ESUS_PEC_DB_PASSWORD=
ESUS_PEC_DB_SSL=false

# Monitor APS — Configurações do Município
MONITOR_APS_MUNICIPIO_IBGE=3131703
MONITOR_APS_MUNICIPIO_NOME=Ilicínea
MONITOR_APS_ESTRATO_IED=4

# Monitor APS — Performance (0 = desabilitar cache em dev)
MONITOR_APS_CACHE_TTL_SECONDS=300

# Monitor APS — Porta do servidor backend (não expor no frontend)
MONITOR_APS_PORT=3001

# sysdoc_front: URL do backend Monitor APS (proxy rewrites em next.config.js)
MONITOR_APS_BACKEND_URL=http://localhost:3001
